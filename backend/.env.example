# ============================================
# MUNTANER336 Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# DISCOGS API
# Get these from: https://www.discogs.com/settings/developers
# ============================================
DISCOGS_CONSUMER_KEY=your_consumer_key_here
DISCOGS_CONSUMER_SECRET=your_consumer_secret_here
DISCOGS_USERNAME=muntaner336

# ============================================
# MERCADO PAGO
# Get these from: https://www.mercadopago.com.mx/developers
# ============================================
MP_ACCESS_TOKEN=your_access_token_here
MP_PUBLIC_KEY=your_public_key_here

# ============================================
# BREVO (SENDINBLUE) EMAIL
# Get from: https://app.brevo.com/settings/keys/api
# ============================================
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_ID=2

# ============================================
# WHATSAPP
# Format: country code + number (no + or spaces)
# ============================================
WHATSAPP_NUMBER=5255879475564

# ============================================
# SERVER CONFIG
# ============================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000,https://muntaner336.com

# Optional: API key for admin endpoints
ADMIN_API_KEY=your_secret_admin_key

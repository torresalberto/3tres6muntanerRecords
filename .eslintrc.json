{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "indent": ["warn", 4],
    "linebreak-style": ["error", "unix"]
  },
  "ignorePatterns": ["node_modules/", "*.min.js", "dist/", "downloads/", "validate_fixes.js"]
}

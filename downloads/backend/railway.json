{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "install": ["python3", "npm"]
    },
    "buildCommand": "YOUTUBE_DL_SKIP_PYTHON_CHECK=1 npm install",
    "startCommand": "YOUTUBE_DL_SKIP_PYTHON_CHECK=1 npm start"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
